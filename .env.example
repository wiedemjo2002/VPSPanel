# Copy to .env. The installer creates secure values automatically.
VPSPANEL_VERSION=0.2.0
PANEL_SITE_ADDRESS=:8080
PANEL_PUBLIC_URL=http://localhost:8080
POSTGRES_DB=vpspanel
POSTGRES_USER=vpspanel
POSTGRES_PASSWORD=change-me
SESSION_SECRET=change-me
AGENT_TOKEN=change-me

# Optional GitHub OAuth App. The callback URL is:
# https://panel.example.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
